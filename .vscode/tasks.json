{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "..",
        "-G", "MinGW Makefiles",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "options": { "cwd": "${workspaceFolder}/build" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "mingw32-make",
      "args": ["-j4"],
      "options": { "cwd": "${workspaceFolder}/build" },
      "group": { "kind": "build", "isDefault": true },
      "dependsOn": "CMake Configure Debug",
      "problemMatcher": "$gcc"
    },
    {
      "label": "CMake Configure Release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "..",
        "-G", "MinGW Makefiles",
        "-DCMAKE_BUILD_TYPE=Release"
      ],
      "options": { "cwd": "${workspaceFolder}/build" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build Release",
      "type": "shell",
      "command": "mingw32-make",
      "args": ["-j4"],
      "options": { "cwd": "${workspaceFolder}/build" },
      "group": "build",
      "dependsOn": "CMake Configure Release",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Run",
      "type": "shell",
      "command": "${workspaceFolder}/build/ZombieSurvival3D.exe",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Create Build Dir",
      "type": "shell",
      "command": "mkdir",
      "args": ["-Force", "build"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
